{
  "name": "@terminalmind/ext-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "terminalmind": {
    "entry": "./src/index.ts",
    "activationEvents": ["onCommand:ai.*", "onView:ai-chat"],
    "contributions": {
      "commands": [
        { "id": "ai.openSidebar", "title": "AI: Open Chat Panel" },
        { "id": "ai.generateCommand", "title": "AI: Generate Command" },
        { "id": "ai.clearConversation", "title": "AI: Clear Conversation" },
        { "id": "ai.sendToTerminal", "title": "AI: Send Command to Terminal" },
        { "id": "ai.settings", "title": "AI: Settings" }
      ],
      "views": {
        "sidebar": [{ "id": "ai-chat", "name": "AI Chat" }]
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@terminalmind/api": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
