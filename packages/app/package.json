{
  "name": "@terminalmind/app",
  "version": "0.1.0",
  "private": true,
  "description": "CLI-First intelligent terminal for full-stack developers",
  "author": "TerminalMind Team",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-builder",
    "build:win": "node scripts/build-win.mjs",
    "build:mac": "node scripts/build-mac.mjs",
    "build:linux": "node scripts/build-linux.mjs"
  },
  "dependencies": {
    "@terminalmind/api": "workspace:*",
    "@terminalmind/core": "workspace:*",
    "@terminalmind/ext-ai": "workspace:*",
    "@terminalmind/ext-connections": "workspace:*",
    "@terminalmind/ext-sftp": "workspace:*",
    "@terminalmind/ext-ssh": "workspace:*",
    "@terminalmind/ext-terminal": "workspace:*",
    "@terminalmind/services": "workspace:*",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-webgl": "^0.18.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-vite": "^3.0.0",
    "electron-builder": "^25.0.0",
    "@electron/rebuild": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
